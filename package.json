{
  "name": "liquimint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "compile": "npx hardhat compile",
    "deploy:amoy": "npx hardhat run --network amoy scripts/deploy.js",
    "deploy:governance": "npx hardhat run --network amoy scripts/deploy-governance.js",
    "deploy:dexmocks": "npx hardhat run --network amoy scripts/deploy-dex-mocks.js",
    "deploy:bonding": "npx hardhat run --network amoy scripts/deploy-bonding.js",
    "deploy:security": "npx hardhat run --network amoy scripts/deploy-security.js",
    "deploy:all": "npx hardhat run --network amoy scripts/deploy-all.js",
    "deploy:complete": "npm run compile && npm run deploy:all",
    "verify:postdeploy": "npx hardhat run --network amoy scripts/post-deploy-checks.js",
    "set:reputation": "npx hardhat run --network amoy scripts/setReputation.js",
    "sync:frontend": "node scripts/sync-frontend.js",
    "test": "npx hardhat test",
    "test:coverage": "npx hardhat coverage",
    "start:dex": "npm run dev"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.2",
    "clsx": "^2.1.0",
    "date-fns": "^3.0.0",
    "dset": "^3.1.4",
    "ethers": "^6.15.0",
    "framer-motion": "12.23.19",
    "lucide-react": "^0.544.0",
    "motion": "^12.23.22",
    "next": "^16.0.10",
    "pino-pretty": "^13.1.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "socket.io-client": "^4.7.0",
    "viem": "^2.37.11",
    "wagmi": "^2.17.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "hardhat": "^2.26.3",
    "postcss": "^8.5.6",
    "recharts": "^2.8.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5"
  }
}
