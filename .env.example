# LiquiMint Environment Configuration

# Blockchain
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_RPC_URL=https://polygon-rpc.com/
# Optional legacy fallback if AMOY_RPC_URL / POLYGON_RPC_URL are unset:
RPC_URL=
PRIVATE_KEY=YOUR_TESTNET_PRIVATE_KEY
CHAIN_ID=80002

# AI / Simulation APIs
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
TENDERLY_API_KEY=YOUR_TENDERLY_API_KEY
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=

# Deployment inputs (required for deploy scripts)
DEX_ROUTER=YOUR_AMOY_DEX_ROUTER_ADDRESS
GOVERNANCE_OWNER=0xYourMultisigOrTimelockAddress
GOVERNANCE_PROPOSER=0xYourMultisigAddress
GOVERNANCE_EXECUTOR=0xYourMultisigAddress
TIMELOCK_MIN_DELAY=86400
LIQUIDITY_CONTROLLER=
BONDING_FACTORY=

# Frontend contract addresses (set by deploy scripts)
NEXT_PUBLIC_BONDING_FACTORY=
NEXT_PUBLIC_LIQUIDITY_CONTROLLER=

# Frontend app config
NEXT_PUBLIC_NETWORK_NAME=Polygon Amoy Testnet
NEXT_PUBLIC_EXPLORER_URL=https://amoy.polygonscan.com/
NEXT_PUBLIC_APP_NAME=LiquiMint
NEXT_PUBLIC_APP_URL=http://localhost:3000
